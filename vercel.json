{
  "buildCommand": "cd web && npm ci && npm run build",
  "outputDirectory": "web/dist",
  "installCommand": "cd web && npm ci",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/health", "destination": "/health" }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}

